# DTH Capture Configuration

# Capture Device
VIDEO_DEV=/dev/video0
AUDIO_CARD=hw:3,0
CHANNEL_NAME=cnbc-awaaz

# ffmpeg
RESOLUTION=1280x720
FRAMERATE=30
X264_PRESET=veryfast
VIDEO_CRF=28
SEGMENT_SECS=60
AUDIO_BITRATE=96k

# Segment validation
MIN_SEGMENT_SECS=55
STALE_WARN_SECS=90

# MinIO
MINIO_ENDPOINT=192.168.1.10:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dth-chunks
MINIO_SECURE=false

# Upload retry
UPLOAD_RETRIES=5
UPLOAD_RETRY_DELAY=5

# MongoDB
MONGODB_URI=mongodb://192.168.1.10:27017
MONGODB_DATABASE=dth

# RabbitMQ
RABBITMQ_HOST=192.168.1.10
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=stock-market-jobs
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
